<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ZERO Bookmark Manager</title>
    <link rel="icon" href="favicon.png" type="image/png">
    <link href="https://fonts.googleapis.com/css2?family=Press+Start+2P&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Press Start 2P', cursive;
            margin: 0;
            padding: 0;
            background: #000;
            color: #fff;
            text-align: center;
        }

        header {
            padding: 50px 20px;
        }

        header img {
            width: 250px;
        }

        .btn {
            display: inline-block;
            margin-top: 20px;
            padding: 15px 25px;
            background: #fff;
            color: #000;
            text-decoration: none;
            border-radius: 8px;
            font-weight: bold;
        }

        section {
            padding: 60px 20px;
        }

        .features {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 20px;
            max-width: 1000px;
            margin: auto;
        }

        .feature {
            background: #111;
            padding: 20px;
            border-radius: 12px;
        }

        footer {
            padding: 30px;
            background: #111;
            font-size: 12px;
        }
    </style>
</head>

<body>
    <header>
        <img src="logo.png" alt="ZERO Logo">
        <h1>ZERO Bookmark Manager</h1>
        <p>Simple. Fast. Powerful Bookmark Manager.</p>
        <a href="#" class="btn">Install Extension</a>
    </header>

    <section>
        <h2>Features</h2>
        <div class="features">
            <div class="feature">📑 Easy Bookmark Management</div>
            <div class="feature">🌗 Dark & Light Mode</div>
            <div class="feature">📂 Quick Folder Creation</div>
            <div class="feature">🔍 Instant Search</div>
        </div>
    </section>

    <section>
        <h2>How it works</h2>
        <p>1. Install → 2. Save → 3. Search → 4. Manage</p>
        <img src="demo.gif" alt="Demo" width="400">
    </section>

    <section>
        <h2>Privacy & Support</h2>
        <p><a href="privacy.html">Privacy Policy</a></p>
        <p>Contact: <a href="mailto:support@yourmail.com">support@yourmail.com</a></p>
    </section>

    <footer>
        © 2025 ZERO Bookmark Manager
    </footer>
</body>

</html>